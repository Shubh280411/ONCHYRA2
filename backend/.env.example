PORT=5000
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON=  # Use this instead of KEY_PATH on Render (paste entire JSON)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password
OTP_GMAIL_USER=your-otp-email@gmail.com
OTP_GMAIL_PASS=your-otp-app-password
# Gmail Apps Script avoids Render SMTP timeouts and still sends from Gmail.
# EMAIL_PROVIDER=apps_script
# GMAIL_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
# GMAIL_APPS_SCRIPT_SECRET=your-shared-secret
# MAIL_FROM_EMAIL=onchyra.support@gmail.com
# OTP_MAIL_FROM_EMAIL=onchyra.support@gmail.com
CORS_ORIGIN=*
HD_WALLET_SEED="your wallet seed phrase"
BSC_RPC=https://bsc-dataseed1.binance.org
POLYGON_RPC=https://polygon-bor.publicnode.com
SWEEP_GAS_AMOUNT=0.000003
MONITOR_INTERVAL=300000
WITHDRAWAL_SEED_PHRASE="your withdrawal seed phrase"
REWARD_INTERVAL=300000
